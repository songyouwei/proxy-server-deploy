REPO_URL=https://github.com/songyouwei/proxy-server-deploy.git
BRANCH=main
INSTALL_DIR=/opt/proxy-server-deploy

PROXY_DOMAIN=proxy.example.com
SITE_DOMAIN=proxy.example.com
ACME_EMAIL=admin@example.com
NAIVE_USER=proxy
# NAIVE_PASSWORD=
