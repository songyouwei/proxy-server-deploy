# Override only when deploying from a fork or private repository.
# REPO_URL=https://github.com/songyouwei/proxy-server-deploy.git
BRANCH=main
INSTALL_DIR=/opt/proxy-server-deploy

PROXY_DOMAIN=proxy.example.com
SITE_DOMAIN=proxy.example.com
ACME_EMAIL=admin@example.com
NAIVE_USER=proxy
# NAIVE_PASSWORD=
# VMESS_UUID=
WS_PATH=/test
AUTO_CONFIG=auto
CLIENT_ENV_FILE=.deploy-client.env
# SKIP_FIREWALL_CONFIG=0

# Optional existing website directory on the target server.
# WEB_LOCAL_DIR=/srv/www

# Default generated website directory when WEB_LOCAL_DIR is not set.
# WEB_DIR=www
